// Schema Prisma - Alumni Dashboard RBAC
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  cargo        String    // Job title (Diretor, Analista, etc.)
  role         Role      @relation(fields: [roleId], references: [id])
  roleId       String
  isActive     Boolean   @default(true)
  isDemoUser   Boolean   @default(false) // Flag para usuarios demo migrados
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  // Relations
  sessions     Session[]
  activityLogs ActivityLog[]
  createdBy    User?     @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdById  String?
  usersCreated User[]    @relation("UserCreatedBy")

  @@index([email])
  @@index([roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([token])
}

// ============================================================
// RBAC - ROLES & PERMISSIONS
// ============================================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // ADM, Investidor, Customer Care, Marketing
  displayName String   // Nome para exibicao
  description String?
  isSystem    Boolean  @default(false) // Roles do sistema nao podem ser deletados
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "module:vendas-b2c:view", "admin:users:manage"
  name        String   // Nome legivel
  description String?
  category    String   // "module", "admin", "activity"

  // Relations
  roles RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ============================================================
// ACTIVITY MONITORING
// ============================================================

model ModuleDataSnapshot {
  id           String   @id @default(cuid())
  moduleId     String   @unique // vendas_b2c, vendas_b2b, etc.
  contentHash  String   // SHA-256 do conteudo da planilha
  rowCount     Int
  lastModified DateTime @default(now())
  sourceUrl    String?

  @@index([moduleId])
}

model ActivityLog {
  id          String       @id @default(cuid())
  type        ActivityType
  moduleId    String?      // vendas_b2c, marketing, etc.
  description String
  metadata    Json?        // Dados adicionais (hash antigo, novo, etc.)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  ipAddress   String?
  createdAt   DateTime     @default(now())

  @@index([moduleId, createdAt])
  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

enum ActivityType {
  DATA_UPDATED    // Dados da planilha foram alterados
  DATA_NO_CHANGE  // Verificacao diaria nao encontrou alteracoes
  DATA_REFRESH    // Refresh manual ou automatico executado
  DATA_ERROR      // Erro ao buscar dados
  USER_LOGIN      // Usuario fez login
  USER_LOGOUT     // Usuario fez logout
  USER_CREATED    // Novo usuario criado
  USER_UPDATED    // Usuario atualizado
  USER_DELETED    // Usuario desativado
  ROLE_CHANGED    // Role do usuario alterado
  CONFIG_CHANGED  // Configuracao do dashboard alterada
}

// ============================================================
// SCHEDULED TASKS TRACKING
// ============================================================

model ScheduledTaskRun {
  id           String   @id @default(cuid())
  taskName     String   // "refresh_all_data", "daily_check"
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  status       String   // "running", "completed", "failed"
  result       Json?    // Resultados por modulo
  errorMessage String?

  @@index([taskName, startedAt])
  @@index([status])
}

// ============================================================
// CONTRATOS B2B - MÓDULO DE CONTRATOS
// ============================================================

model Company {
  id                String     @id @default(cuid())
  razaoSocial       String
  cnpj              String     @unique
  endereco          String?
  cidade            String?
  estado            String?
  cep               String?
  representanteNome String?
  representanteCpf  String?
  representanteEmail String?
  representanteTelefone String?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  contracts         Contract[]

  @@index([cnpj])
  @@index([razaoSocial])
}

model ContractTemplate {
  id          String   @id @default(cuid())
  name        String   // "Master Agreement Alumni", "Anexo Comercial Better"
  type        ContractType
  brand       String   // "alumni", "better"
  htmlContent String   @db.Text // HTML template com {{variaveis}}
  clauses     Json?    // Clausulas base do template
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts   Contract[]

  @@index([type, brand])
}

model Contract {
  id              String         @id @default(cuid())
  number          String         @unique // Numero sequencial: CTR-2026-001
  title           String
  type            ContractType
  status          ContractStatus @default(DRAFT)
  brand           String         // "alumni", "better"

  // Relacoes
  company         Company        @relation(fields: [companyId], references: [id])
  companyId       String
  template        ContractTemplate? @relation(fields: [templateId], references: [id])
  templateId      String?

  // Dados do contrato (variáveis preenchidas)
  contractData    Json           // Todos os dados estruturados (variaveis)

  // HTML editado atual (versão mais recente)
  htmlContent     String         @db.Text

  // Financeiro
  valorTotal      Float?
  formaPagamento  String?
  diaEmissaoNf    Int?
  diaVencimento   Int?

  // Prazo
  dataInicio      DateTime?
  dataFim         DateTime?
  prazoMeses      Int?

  // Programas contratados
  programs        ContractProgram[]

  // Versionamento
  versions        ContractVersion[]
  currentVersion  Int            @default(1)

  // Assinatura
  zapsignDocId    String?        // ID do documento no ZapSign
  zapsignStatus   String?        // Status da assinatura
  signedAt        DateTime?
  signatories     ContractSignatory[]

  // Arquivos gerados
  files           ContractFile[]

  // Auditoria
  createdById     String?
  updatedById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([brand])
  @@index([type])
  @@index([createdAt])
}

model ContractProgram {
  id            String   @id @default(cuid())
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId    String
  tipoPrograma  String   // "Community", "Community Flow", "Particular", "Conexion"
  quantidade    Int      // Numero de alunos
  valorUnitario Float
  valorTotal    Float
  descricao     String?

  @@index([contractId])
}

model ContractVersion {
  id          String   @id @default(cuid())
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId  String
  version     Int
  htmlContent String   @db.Text // HTML completo desta versao
  contractData Json    // Dados estruturados desta versao
  changeNote  String?  // Descricao da mudanca
  createdById String?
  createdAt   DateTime @default(now())

  @@unique([contractId, version])
  @@index([contractId])
}

model ContractFile {
  id          String   @id @default(cuid())
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId  String
  type        FileType // PDF ou DOCX
  version     Int      // Versao do contrato quando gerado
  fileName    String
  fileUrl     String   // URL no S3 ou Vercel Blob
  fileSize    Int?
  createdAt   DateTime @default(now())

  @@index([contractId])
}

model ContractSignatory {
  id              String   @id @default(cuid())
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId      String
  name            String
  email           String
  cpf             String?
  role            String   // "contratante", "contratada"
  signatoryType   String   @default("responsavel") // "responsavel", "testemunha"
  status          String   @default("pending") // "pending", "signed", "refused"
  signUrl         String?  // URL individual de assinatura no ZapSign
  signedAt        DateTime?
  zapsignSignerId String?  // Token do signatario no ZapSign
  createdAt       DateTime @default(now())

  @@index([contractId])
}

model BrandConfig {
  id            String   @id @default(cuid())
  brand         String   @unique // "alumni", "better"
  displayName   String   // "Alumni", "Better EdTech"
  logoUrl       String?
  primaryColor  String   @default("#3B82F6")
  secondaryColor String  @default("#8B5CF6")
  footerText    String?  @db.Text
  cnpj          String?
  endereco      String?
  telefone      String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum ContractType {
  CORPORATIVO
  IN_COMPANY
  AULAS_PARTICULARES
  PARCERIA
  LICENCIAMENTO
}

enum ContractStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT_FOR_SIGNATURE
  SIGNED
  ACTIVE
  CANCELLED
  EXPIRED
}

enum FileType {
  PDF
  DOCX
}

// ============================================================
// CONTRATOS B2C - MÓDULO DE CONTRATOS INDIVIDUAIS
// ============================================================

model B2CContract {
  id              String   @id @default(cuid())
  number          String   @unique
  title           String
  type            String   // "PRIVATE", "COMMUNITY", "COMMUNITY_FLOW"
  status          String   @default("DRAFT") // DRAFT, REVIEW, SENT_FOR_SIGNATURE, SIGNED, ACTIVE, CANCELLED
  brand           String   @default("alumni")

  // Dados do aluno
  nomeAluno       String
  cpfAluno        String
  emailAluno      String
  telefoneAluno   String?
  enderecoAluno   String?

  // Financeiro
  valorTotal      Float    @default(0)
  formaPagamento  String?
  tipoCobranca    String?  // "mensal", "pacote"
  parcelas        Int?
  faturamentoHibrido Boolean @default(false)

  // Campos específicos por tipo (JSON flexível)
  contractData    Json?

  // Conteúdo
  templateId      String?
  htmlContent     String   @db.Text
  currentVersion  Int      @default(1)

  // ZapSign
  zapsignDocId    String?
  zapsignStatus   String?
  signedAt        DateTime?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  versions        B2CContractVersion[]
  signatories     B2CContractSignatory[]

  @@index([status])
  @@index([type])
  @@index([cpfAluno])
}

model B2CContractVersion {
  id            String   @id @default(cuid())
  contract      B2CContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId    String
  version       Int
  htmlContent   String   @db.Text
  contractData  Json?
  changeNote    String?
  createdAt     DateTime @default(now())

  @@unique([contractId, version])
  @@index([contractId])
}

model B2CContractSignatory {
  id              String   @id @default(cuid())
  contract        B2CContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId      String
  name            String
  email           String
  cpf             String?
  role            String   @default("aluno")
  status          String   @default("pending")
  signUrl         String?
  signedAt        DateTime?
  zapsignSignerId String?
  createdAt       DateTime @default(now())

  @@index([contractId])
}

model B2CContractTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // "PRIVATE", "COMMUNITY", "COMMUNITY_FLOW"
  brand       String   @default("alumni")
  htmlContent String   @db.Text
  variables   Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
